
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<title>Chúc Mừng 8/3 💖</title>

<link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Quicksand:wght@400;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    height:100vh;
    background:linear-gradient(135deg,#ff9ecf,#ffd6ec,#ffc2e2);
    display:flex;
    justify-content:center;
    align-items:center;
    font-family:'Quicksand',sans-serif;
    overflow:hidden;
}

/* CARD */
.card{
    background:white;
    padding:40px;
    border-radius:25px;
    text-align:center;
    box-shadow:0 15px 40px rgba(0,0,0,0.2);
    width:360px;
    position:relative;
    z-index:10;
    animation:fadeIn 1.5s ease;
}

h1{
    font-family:'Pacifico',cursive;
    font-size:30px;
    color:#ff4da6;
}

p{
    margin-top:15px;
    font-size:17px;
    color:#555;
}

input{
    margin-top:20px;
    padding:12px;
    width:100%;
    border-radius:25px;
    border:1px solid #ff4da6;
    outline:none;
    text-align:center;
    font-size:15px;
}

button{
    margin-top:20px;
    padding:12px 25px;
    border:none;
    border-radius:30px;
    background:#ff4da6;
    color:white;
    font-size:16px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#ff1a8c;
    transform:scale(1.1);
}

#message{
    margin-top:20px;
    font-weight:bold;
    color:#ff3399;
}

#giftImage{
    display:none;
    margin-top:20px;
    width:100%;
    border-radius:15px;
    animation:zoomIn 1s ease forwards;
}

/* HEART */
.heart{
    position:absolute;
    animation:floatUp 4s linear infinite;
}

@keyframes floatUp{
    0%{ transform:translateY(0) scale(1); opacity:1; }
    100%{ transform:translateY(-800px) scale(1.5); opacity:0; }
}

@keyframes fadeIn{
    from{opacity:0; transform:translateY(50px);}
    to{opacity:1; transform:translateY(0);}
}

@keyframes zoomIn{
    from{transform:scale(0.5); opacity:0;}
    to{transform:scale(1); opacity:1;}
}
</style>
</head>

<body>

<div class="card">
    <h1>Chúc Mừng 8/3 🌸</h1>
    <img class="header-image"
     src="https://scontent.fsgn5-5.fna.fbcdn.net/v/t39.30808-6/645500551_2122970441812999_3359133274551270121_n.jpg?_nc_cat=100&ccb=1-7&_nc_sid=13d280&_nc_eui2=AeGkrVEEGS7W6pXmQwEmhr35o6z0mq_xceOjrPSar_Fx46vZIFxgb77l0ZtUM-NMasRHeSIdqrl2jSaqffvB_MYT&_nc_ohc=Dq0xCkhruHMQ7kNvwFtIN3u&_nc_oc=Adm_PGnrw75-RexdDx5qqBRXEIijZxG4cFXInNc91dWUrmkrfDB36lYlxWmdkP7UXPQ&_nc_zt=23&_nc_ht=scontent.fsgn5-5.fna&_nc_gid=VnTmMgucKIbf2MGfTlUkWA&_nc_ss=8&oh=00_Afu0VUVuyZA-18EUKCQ6pawtcJcNZ0qs0iMSX4epcV2jgg&oe=69AA2D80"
     alt="Ảnh 8/3 dễ thương"
     style="width:200px; height:200px; object-fit:cover; display:block; margin:20px auto; border-radius:20px;">
    <p>Nhập mật khẩu để mở quà bí mật 🎁</p>

    <input type="password" id="passwordInput" placeholder="Nhập mật khẩu...">
    <button onclick="checkPassword()">Mở Quà 💌</button>

    <div id="message"></div>

    <!-- Ảnh quà (bạn có thể thay link ảnh của riêng bạn vào đây) -->
    <img id="giftImage" 
    src="https://scontent.fsgn5-3.fna.fbcdn.net/v/t39.30808-6/644113360_2122970658479644_5788638324173951982_n.jpg?_nc_cat=104&ccb=1-7&_nc_sid=13d280&_nc_eui2=AeH93bCykiF2sS48HOmysVhldXh_eSsyDGN1eH95KzIMY1mGdug_hW1pZDEaX3Q6KZI9SP2ZG9j5juuh63J0hU7K&_nc_ohc=FokPQWWZOEAQ7kNvwFMcpIc&_nc_oc=Adns4dtotE_6mx-TImmnKz0eU8EnE5rhRC5Iuk3-mwQS-Du6VUv-NJpNNH7S5kJUb2o&_nc_zt=23&_nc_ht=scontent.fsgn5-3.fna&_nc_gid=YJaCyFvvfYfeftoKeCltVA&_nc_ss=8&oh=00_AfuJtUZ6o42903hqXufgdA_g5mqo5betMoyjdsdhELNmEA&oe=69AA3A0B" 
    alt="Quà 8/3">
</div>

<script>
const correctPassword = "17102025"; // 🔐 Đổi mật khẩu tại đây

function checkPassword(){
    let password = document.getElementById("passwordInput").value;
    let message = document.getElementById("message");
    let image = document.getElementById("giftImage");

    if(password === correctPassword){
        message.innerHTML = "💖 Anh chúc Shi của anh 8/3 hạnh phúc và ngày càng yêu thương anh hơn, ở nhà học ngoan nha không có quậy và luôn xinh đẹp! 🌷✨";
        image.style.display = "block";
    }else{
        message.innerHTML = "Sai mật khẩu rồi 😝 Thử lại nhé!";
        image.style.display = "none";
    }
}

/* Tạo hiệu ứng tim bay */
function createHeart(){
    const heart = document.createElement("div");
    heart.classList.add("heart");
    heart.innerHTML = "💖";
    heart.style.left = Math.random()*100 + "vw";
    heart.style.bottom = "-20px";
    heart.style.fontSize = (Math.random()*20 + 15) + "px";
    document.body.appendChild(heart);

    setTimeout(()=>{
        heart.remove();
    },4000);
}

setInterval(createHeart,300);

/* Nhấn Enter để mở quà */
document.getElementById("passwordInput")
.addEventListener("keypress",function(e){
    if(e.key === "Enter"){
        checkPassword();
    }
});
</script>

</body>
</html>
